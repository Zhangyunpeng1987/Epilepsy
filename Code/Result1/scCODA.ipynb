  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "1820b8fe-6538-4663-b8e4-d14db20b4c41",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 确保 sample 列是字符串\n",
    "cell_counts[\"sample\"] = cell_counts[\"sample\"].astype(str)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "e4df0db9-8166-486e-9736-20c2ea212ad3",
   "metadata": {},
   "outputs": [],
   "source": [
    "#根据 sample 前缀生成 Group\n",
    "cell_counts[\"Group\"] = cell_counts[\"sample\"].str.extract(r\"^(Ep|Nor)\")[0]\n",
    "\n",
    "# 可选：把它变成更明确的分类\n",
    "cell_counts[\"Group\"] = cell_counts[\"Group\"].map({\"Ep\": \"Ep\", \"Nor\": \"Nor\"})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "11ccec26-d51f-413e-8bc6-ffd2fe77d42e",
   "metadata": {},
   "outputs": [],
   "source": [
    "sample_meta = pd.DataFrame({\n",
    "    \"sample\": [\"Ep1\",\"Ep2\",\"Ep3\",\"Ep4\",\"Ep5\",\"Ep6\",\"Ep7\",\"Ep8\",\"Ep9\",\n",
    "               \"Nor1\",\"Nor2\",\"Nor3\",\"Nor4\",\"Nor5\",\"Nor6\",\"Nor7\",\"Nor8\",\"Nor9\",\"Nor10\"],\n",
    "    \"Age\":    [\"Adult\",\"Adult\",\"Adult\",\"Adult\",\"Adult\",\"Adult\",\"Adult\",\"Adult\",\"Adult\",\n",
    "               \"Old\",\"Adult\",\"Adult\",\"Old\",\"Old\",\"Old\",\"Old\",\"Adult\",\"Adult\",\"Adult\"],\n",
    "    \"Sex\":    [\"Female\",\"Male\",\"Male\",\"Female\",\"Female\",\"Male\",\"Female\",\"Female\",\"Male\",\n",
    "               \"Male\",\"Male\",\"Male\",\"Female\",\"Female\",\"Male\",\"Male\",\"Male\",\"Female\",\"Female\"]\n",
    "})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "29cb0ed6-26d6-4a15-a620-4c05f4d1e075",
   "metadata": {},
   "outputs": [],
   "source": [
    "cell_counts = cell_counts.merge(sample_meta, on=\"sample\", how=\"left\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "9c6d4dfe-5852-45e1-9cf7-1c813e774eb3",
   "metadata": {},
   "outputs": [],
   "source": [
    "# 检查有没有没匹配到的样本\n",
    "missing = cell_counts[cell_counts[\"Age\"].isna() | cell_counts[\"Sex\"].isna()]\n",
    "if len(missing) > 0:\n",
    "    print(\"Missing meta for samples:\", missing[\"sample\"].tolist())"
   ]
  },
  {
   "cell_type": "code",
